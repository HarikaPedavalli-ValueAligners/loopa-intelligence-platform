ENVIRONMENT=development
SQLITE_DB_PATH=loopa_intelligence.db

# AI provider
AI_PROVIDER=groq
AI_ENABLE_FALLBACK=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_openai_model_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_THINKING_BUDGET=
VERTEX_API_KEY=your_vertex_express_api_key_here
VERTEX_MODEL=gemini-3-pro-preview
VERTEX_THINKING_BUDGET=
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Azure SQL, required when ENVIRONMENT=production
AZURE_SQL_SERVER=your_server.database.windows.net
AZURE_SQL_DATABASE=your_database_name
AZURE_SQL_USERNAME=your_username
AZURE_SQL_PASSWORD=your_password
AZURE_SQL_PORT=1433
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
AZURE_SQL_ENCRYPT=yes
AZURE_SQL_TRUST_SERVER_CERTIFICATE=no
