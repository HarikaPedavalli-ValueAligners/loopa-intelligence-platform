# Loopa Intelligence Platform - example environment file.
# Copy to .env and fill in real values. NEVER commit the real .env.
#
# --- Existing platform settings (unchanged) ---
GROQ_API_KEY=your_groq_api_key_here
AZURE_SQL_SERVER=your_server.database.windows.net
AZURE_SQL_DATABASE=your_database_name
AZURE_SQL_USERNAME=your_username
AZURE_SQL_PASSWORD=your_password
ENVIRONMENT=development

# --- Loopa SaaS wrapper settings (new) ---
# Master feature flag. The SaaS API and multi-tenant layer are INERT unless
# this is exactly "true". Default OFF keeps existing platform behavior intact.
LOOPA_SAAS_ENABLED=false

# Secret used to sign/verify admin operations (e.g. minting tenant API keys).
# Generate a long random string. If unset, admin endpoints are disabled.
LOOPA_SAAS_ADMIN_TOKEN=

# Default plan assigned to newly provisioned tenants. One of: free, pro, enterprise.
LOOPA_SAAS_DEFAULT_PLAN=free

# Optional per-tenant rate-limit override (requests/minute) for the free tier.
# Falls back to the built-in plan default when unset.
LOOPA_SAAS_FREE_RATE_PER_MIN=
